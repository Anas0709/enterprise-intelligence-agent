# Enterprise Intelligence Agent - Configuration
# Copy to .env and fill in your values

# Required for full AI capabilities
OPENAI_API_KEY=

# Database (default: SQLite)
DATABASE_URL=sqlite:///./data/enterprise.db

# Pre-trained model path
MODEL_PATH=models/model.pkl

# LLM model name (OpenAI)
LLM_MODEL=gpt-4o-mini

# Set to true for mock/stub responses when no API key
# MOCK_LLM_MODE=false
